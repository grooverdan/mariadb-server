# 1) Prepare

# 2) Create table

CREATE TABLE test_table (
id INT PRIMARY KEY,
name VARCHAR(32),
index idx_id(name),
unique index uk_name(name),
unique index uk_id(id),
unique index uk_id_name(id,name)
) engine=duckdb;
DROP TABLE test_table;
