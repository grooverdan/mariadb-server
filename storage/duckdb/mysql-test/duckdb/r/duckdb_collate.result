CREATE TABLE t1 (col1 VARCHAR(20) COLLATE utf8mb4_0900_ai_ci PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES ('B'), ('a'), ('b');
#
# 1) modify the scope of default_collation to local
