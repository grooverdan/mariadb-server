#
# MDEV-39535 Server crash or assertion failure upon HANDLER operations on a partitioned table
#
# original case 1
CREATE TABLE t (pk YEAR PRIMARY KEY) ENGINE=InnoDB
PARTITION BY key (pk) PARTITIONS 2;
INSERT INTO t VALUES (2001);
SELECT * FROM t WHERE pk = 3000;
pk
HANDLER t OPEN;
HANDLER t READ NEXT;
pk
2001
HANDLER t READ `PRIMARY` PREV;
pk
HANDLER t READ `PRIMARY` PREV;
pk
DROP TABLE t;
# original case 2
CREATE TABLE t (pk YEAR PRIMARY KEY) ENGINE=InnoDB
PARTITION BY key (pk) PARTITIONS 2;
INSERT INTO t VALUES (2001);
SELECT * FROM t WHERE pk = 3000;
pk
HANDLER t OPEN;
HANDLER t READ `PRIMARY` PREV;
pk
HANDLER t READ `PRIMARY` PREV;
pk
DROP TABLE t;
# asc index prev
CREATE TABLE t1 (a INT, KEY(a asc)) PARTITION BY HASH(a);
HANDLER t1 OPEN h;
HANDLER h READ a PREV;
a
HANDLER h READ a PREV;
a
HANDLER h CLOSE;
DROP TABLE t1;
# desc index prev
CREATE TABLE t1 (a INT, KEY(a desc)) PARTITION BY HASH(a);
HANDLER t1 OPEN h;
HANDLER h READ a PREV;
a
HANDLER h READ a PREV;
a
HANDLER h CLOSE;
DROP TABLE t1;
#
# MDEV-39790 Assertion failure upon HANDLER operations on a partitioned table
# MDEV-39805 Server crash in que_fork_get_first_thr
#
## MDEV-39790 original case
CREATE TABLE t1 (c1 INT KEY) PARTITION BY LIST(c1) (PARTITION p1 VALUES IN (1,2,3));
HANDLER t1 OPEN;
HANDLER t1 READ `PRIMARY`=(1);
c1
HANDLER t1 READ `PRIMARY` PREV;
c1
HANDLER t1 READ `PRIMARY` PREV;
c1
DROP TABLE t1;
## MDEV-39805 original case
CREATE TABLE t1 (c1 INT,c2 INT,PRIMARY KEY(c1)) engine=innodb PARTITION BY KEY ALGORITHM=2 (c1) PARTITIONS 20;
HANDLER t1 OPEN AS h1;
HANDLER h1 READ `PRIMARY`=(1);
c1	c2
HANDLER h1 READ `PRIMARY` PREV;
c1	c2
HANDLER h1 READ `PRIMARY` PREV;
c1	c2
drop table t1;
## MDEV-39805 but with NEXT
CREATE TABLE t1 (c1 INT,c2 INT,PRIMARY KEY(c1)) engine=innodb PARTITION BY KEY ALGORITHM=2 (c1) PARTITIONS 20;
HANDLER t1 OPEN AS h1;
HANDLER h1 READ `PRIMARY`=(1);
c1	c2
HANDLER h1 READ `PRIMARY` NEXT;
c1	c2
HANDLER h1 READ `PRIMARY` NEXT;
c1	c2
drop table t1;
