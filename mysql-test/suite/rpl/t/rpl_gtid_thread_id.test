#
#   Verify that GTID log events are written into the binary log along with the
# id of the thread which originally executed the transaction. On the master,
# this is the id of the user connection (or the pseudo_thread_id). The slave
# should maintain this value when binlogging.
#
# References:
#   MDEV-7850:  MariaDB doesn't show thread_id for ROW-based events in binlog
#
--source include/have_binlog_format_row.inc
--source include/master-slave.inc

--connection master
--let master_thread_id=`select connection_id()`
create table t1(a int);
insert into t1 values(1);
optimize table t1;

--sync_slave_with_master

--connection master
--let datadir= `select @@datadir`
--let filename= query_get_value(SHOW MASTER STATUS, File, 1)
--let master_local_binlog=$datadir/$filename
--let master_outfile=$MYSQLTEST_VARDIR/tmp/master_binlog.sql
--echo # MYSQL_BINLOG master_local_binlog > master_outfile
--exec $MYSQL_BINLOG $master_local_binlog > $master_outfile

--let $assert_count= 3
--let $assert_text= Ensure only $assert_count GTID events exist (Master)
--let $assert_select=GTID [0-9]-[0-9]-[0-9]
--let $assert_file= $master_outfile
--source include/assert_grep.inc

--let $assert_text= Ensure each GTID event has the thread id (Master)
--let $assert_select=GTID [0-9]-[0-9]-[0-9].*thread_id=$master_thread_id\$
--source include/assert_grep.inc

--echo #
--echo # GTID event's thread_id should use pseudo_thread_id
--connection master
--let $old_pseudo_id= `SELECT @@SESSION.pseudo_thread_id`
set @@pseudo_thread_id=99999;
insert into t1 values(2);
--echo # MYSQL_BINLOG master_local_binlog > master_outfile
--exec $MYSQL_BINLOG $master_local_binlog > $master_outfile

--let $assert_count= 1
--let $assert_text= GTID event's thread_id should use pseudo_thread_id
--let $assert_select=GTID [0-9]-[0-9]-[0-9].*thread_id=99999\$
--source include/assert_grep.inc

--disable_query_log
--eval set @@pseudo_thread_id=$old_pseudo_id
--enable_query_log


--echo #
--echo # Test the serial slave
--connection slave
--let slave_thread_id=`select connection_id()`
--let datadir= `select @@datadir`
--let filename= query_get_value(SHOW MASTER STATUS, File, 1)
--let slave_local_binlog=$datadir/$filename
--let slave_outfile=$MYSQLTEST_VARDIR/tmp/serial_slave_binlog.sql
--echo # MYSQL_BINLOG slave_local_binlog > slave_outfile
--exec $MYSQL_BINLOG $slave_local_binlog > $slave_outfile

--let $assert_count= 4
--let $assert_text= Ensure the same number of GTID events on the slave as the master
--let $assert_select=GTID [0-9]-[0-9]-[0-9]
--let $assert_file= $slave_outfile
--source include/assert_grep.inc

--let $assert_count= 3
--let $assert_text= Ensure GTID events logged with master's thread id maintain that value
--let $assert_select=GTID [0-9]-[0-9]-[0-9].*thread_id=$master_thread_id\$
--source include/assert_grep.inc

--let $assert_count= 1
--let $assert_text= Ensure GTID event logged with pseudo_thread_id on master maintains that value
--let $assert_select=GTID [0-9]-[0-9]-[0-9].*thread_id=99999\$
--source include/assert_grep.inc


--echo #
--echo # Test the parallel slave
--connection slave
--source include/stop_slave.inc
--let $old_parallel_threads= `SELECT @@GLOBAL.slave_parallel_threads`
SET @@GLOBAL.slave_parallel_threads=1;
--source include/start_slave.inc

--connection master
insert into t1 values(3);
insert into t1 values(4);
--sync_slave_with_master

--connection slave
--echo # MYSQL_BINLOG slave_local_binlog > slave_outfile
--exec $MYSQL_BINLOG $slave_local_binlog > $slave_outfile

--let $assert_count= 6
--let $assert_text= Ensure the same number of GTID events on the slave as the master
--let $assert_select=GTID [0-9]-[0-9]-[0-9]
--source include/assert_grep.inc

--let $assert_count= 5
--let $assert_text= Ensure GTID the new events are logged on the slave with the thread_id of the master thread id
--let $assert_select=GTID [0-9]-[0-9]-[0-9].*thread_id=$master_thread_id\$
--source include/assert_grep.inc

--source include/stop_slave.inc
--eval SET @@GLOBAL.slave_parallel_threads=$old_parallel_threads
--source include/start_slave.inc


--echo #
--echo # MDEV-33924: If pseudo_thread_id is set to 0, thread_id should still be
--echo # written and propagated to slaves
--connection master
--let $old_pseudo_id= `SELECT @@SESSION.pseudo_thread_id`
set @@pseudo_thread_id=0;
insert into t1 values(33924);
--echo # MYSQL_BINLOG master_local_binlog > master_outfile
--exec $MYSQL_BINLOG $master_local_binlog > $master_outfile

--let $assert_count= 1
--let $assert_text= GTID event's thread_id should write pseudo_thread_id value of 0
--let $assert_select=GTID [0-9]-[0-9]-[0-9].*thread_id=0\$
--let $assert_file= $master_outfile
--source include/assert_grep.inc

--sync_slave_with_master
--connection slave
--echo # MYSQL_BINLOG slave_local_binlog > slave_outfile
--exec $MYSQL_BINLOG $slave_local_binlog > $slave_outfile

--let $assert_text= A 0 value for GTID event's thread_id should be propagated on slaves
--let $assert_select=GTID [0-9]-[0-9]-[0-9].*thread_id=0\$
--let $assert_file= $slave_outfile
--source include/assert_grep.inc

--echo # If pseudo_thread_id is set to a value greater than 4 bytes, thread_id
--echo # should be truncated to a 32-bit value in the binary log (see
--echo # MDEV-15089 for details)
--connection master
# Silence the truncation warning
--disable_warnings
set @@pseudo_thread_id=99999999999999999999;
--enable_warnings
insert into t1 values(15089);
--echo # MYSQL_BINLOG master_local_binlog > master_outfile
--exec $MYSQL_BINLOG $master_local_binlog > $master_outfile

--let $assert_count= 1
--let $assert_text= GTID event's thread_id should truncate values higher than 32 bit
--let $assert_select=GTID [0-9]-[0-9]-[0-9].*thread_id=4294967295\$
--let $assert_file= $master_outfile
--source include/assert_grep.inc

--sync_slave_with_master
--connection slave
--echo # MYSQL_BINLOG slave_local_binlog > slave_outfile
--exec $MYSQL_BINLOG $slave_local_binlog > $slave_outfile

--let $assert_text= The truncated thread_id should be preserved on the slave
--let $assert_select=GTID [0-9]-[0-9]-[0-9].*thread_id=4294967295\$
--let $assert_file= $slave_outfile
--source include/assert_grep.inc

--disable_query_log
--connection master
--eval set @@pseudo_thread_id=$old_pseudo_id
--enable_query_log


--echo #
--echo # Cleanup
--connection master
drop table t1;
remove_file $master_outfile;
remove_file $slave_outfile;

--source include/rpl_end.inc
