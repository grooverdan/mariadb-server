connect  con1, localhost, root,,;
[ connection default ]
connection default;
SET collation_connection = 'utf8mb4_0900_as_ci';
[ connection con1 ]
connection con1;
SELECT 'a' = 'A' FROM t1 LIMIT 1;
'a' = 'A'
