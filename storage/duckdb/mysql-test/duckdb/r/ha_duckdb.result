#
# Basic DuckDB handler test: DDL and DML operations
#
# Test 1: CREATE TABLE with various index types
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
id BIGINT NOT NULL,
v VARCHAR(4) NOT NULL,
INDEX ind_v(v),
UNIQUE INDEX uk(v),
PRIMARY KEY (id)
) ENGINE = DuckDB;
# Test 2: INSERT rows
INSERT INTO t1 VALUES (1, '1');
INSERT INTO t1 VALUES (1, '1');
# Test 3: Verify inserted data
SELECT * FROM t1;
id	v
1	1
1	1
