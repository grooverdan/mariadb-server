#
# check collation config when execute
#
create database if not exists charset_and_collation;
use charset_and_collation;
CREATE TABLE t_duckdb  (a varchar(32) PRIMARY KEY, b varchar(32), c varchar(32)) engine=duckdb;
CREATE TABLE t_innodb  (a varchar(32) PRIMARY KEY, b varchar(32), c varchar(32)) engine=innodb;
INSERT INTO t_duckdb VALUES ('a', 'A', 'á');
INSERT INTO t_innodb VALUES ('a', 'A', 'á');
# 1.1 Test for utf8mb4
SET NAMES 'utf8mb4' COLLATE 'utf8mb4_0900_ai_ci';
SELECT 'a'='á' AS ai, 'a'='A' AS ci, 'A'='á' AS ai_ci FROM t_duckdb;
ai	ci	ai_ci
1	1	1
SELECT 'a'='á' AS ai, 'a'='A' AS ci, 'A'='á' AS ai_ci FROM t_innodb;
ai	ci	ai_ci
1	1	1
