# 2) force_no_collation
#
connection default;
SET duckdb_force_no_collation = false;
SELECT * FROM t1 WHERE col1 = 'A';
col1
a
SELECT min(col1) FROM t1;
min(col1)
a
SELECT * FROM t1 ORDER BY col1;
col1
a
B
b
SET duckdb_force_no_collation = true;
SELECT * FROM t1 WHERE col1 = 'A';
col1
a
SELECT min(col1) FROM t1;
min(col1)
a
SELECT * FROM t1 ORDER BY col1;
col1
a
